generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// for Post, visibility can be PUBLIC, FRIENDS, or PRIVATE
enum Visibility {
  PUBLIC
  FRIENDS
  PRIVATE
}

// for Reaction, type can be LIKE, LOVE, HAHA, WOW, SAD, or ANGRY
enum ReactionType {
  LIKE
  LOVE
  HAHA
  WOW
  SAD
  ANGRY
}

// for Friendship, status can be PENDING, ACCEPTED, DECLINED, or REJECTED
enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  REJECTED
}

// for Conversation, type can be PRIVATE or GROUP
enum ConversationType {
  PRIVATE
  GROUP
}

// for ConversationMember, role can be ADMIN or MEMBER
enum ConversationMemberRole {
  ADMIN
  MEMBER
}

// for Message, type can be TEXT, IMAGE, VIDEO, FILE, or LOCATION
enum MessageType {
  TEXT
  IMAGE
  VIDEO
  FILE
  LOCATION
}

// for Location, type can be VISITED or WISHLIST
enum LocationType {
  VISITED
  WISHLIST
}

// for Plan, status can be DRAFT, ACTIVE, COMPLETED, or CANCELLED
enum PlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

// for PlanMember, role can be OWNER, EDITOR, or VIEWER
enum PlanMemberRole {
  OWNER
  EDITOR
  VIEWER
}

// for Task, status can be TODO, IN_PROGRESS, DONE, or CANCELLED
enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

// for Task, priority can be LOW, MEDIUM, HIGH, or URGENT
enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// for Expense, category can be TRANSPORT, ACCOMMODATION, FOOD, ACTIVITY, SHOPPING, or OTHER
enum ExpenseCategory {
  TRANSPORT
  ACCOMMODATION
  FOOD
  ACTIVITY
  SHOPPING
  OTHER
}

// for Notification, type can be REACTION, COMMENT, COMMENT_REPLY, POST_SHARE, FRIEND_REQUEST, FRIEND_ACCEPTED, NEW_MESSAGE, PLAN_INVITE, PLAN_UPDATE, TASK_ASSIGNED, TASK_DONE, or LOCATION_SAVED
enum NotificationType {
  // Social
  REACTION
  COMMENT
  COMMENT_REPLY
  POST_SHARE
  // Friends
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  // Chat
  NEW_MESSAGE
  // Plans
  PLAN_INVITE
  PLAN_UPDATE
  TASK_ASSIGNED
  TASK_DONE
  // Map
  LOCATION_SAVED
}

// for Notification, entityType can be POST, COMMENT, MESSAGE, PLAN, TASK, LOCATION, or FRIENDSHIP
enum NotificationEntityType {
  POST
  COMMENT
  MESSAGE
  PLAN
  TASK
  LOCATION
  FRIENDSHIP
}

// for Device, platform can be WEB, IOS, or ANDROID
enum Platform {
  WEB
  IOS
  ANDROID
}

// User
// ├── Social
// │   ├── Posts
// │   ├── Comments
// │   ├── Reactions
// │   └── Shares
// │
// ├── Friendship
// │   ├── Sent Requests
// │   └── Received Requests
// │
// ├── Chat
// │   ├── Conversations
// │   └── Messages
// │
// ├── Map
// │   ├── Locations
// │   ├── Favorites
// │   └── Photos
// │
// ├── Plans
// │   ├── Created Plans
// │   ├── Members
// │   ├── Tasks
// │   ├── Expenses
// │   └── Plan Messages
// │
// └── Notifications
//     ├── Received
//     ├── Triggered
//     ├── Settings
//     └── Push Tokens

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String?   @map("password_hash")
  provider     String?   
  googleId     String?   @unique @map("google_id")
  githubId     String?   @unique @map("github_id")
  avatarUrl    String?  @map("avatar_url")
  coverUrl     String?  @map("cover_url")
  bio          String?
  isVerified   Boolean  @default(false) @map("is_verified")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // relation fields

  // query example: get user with their posts
  // const user = await prisma.user.findUnique({
  //   where: { id: userId },
  //   include: {
  //     posts: true
  //   }
  // });

  // SQL equivalent: Prisma will generate a LEFT JOIN to fetch the related posts for the user
  // SELECT *
  // FROM users
  // LEFT JOIN posts
  // ON posts.author_id = users.id

  //   {
  //   "id": "u1",
  //   "username": "bach",
  //   "posts": [
  //     {
  //       "id": "p1",
  //       "content": "hello"
  //     },
  //     {
  //       "id": "p2",
  //       "content": "world"
  //     }
  //   ]
  // }

  // Social
  posts            Post[]
  reactions        Reaction[]
  comments         Comment[]
  shares           Share[]

  // Friends & Chat
  sentRequests     Friendship[]          @relation("FriendshipRequester")
  receivedRequests Friendship[]          @relation("FriendshipAddressee")
  conversations    ConversationMember[]
  sentMessages     Message[]

  // Map
  locations        MapLocation[]
  locationFavorites LocationFavorite[]
  locationPhotos   LocationPhoto[]

  // Plans
  createdPlans     Plan[]
  planMemberships  PlanMember[]
  assignedTasks    Task[]
  paidExpenses     Expense[]
  planMessages     PlanMessage[]

  // Notifications
  receivedNotifications Notification[]      @relation("NotificationRecipient")
  triggeredNotifications Notification[]     @relation("NotificationActor")
  notificationSettings  NotificationSetting[]
  pushTokens            PushToken[]

  @@map("users")
}

model Post {
  id         String     @id @default(uuid())
  userId     String     @map("user_id")
  content    String
  mediaUrls  String[]   @map("media_urls")
  visibility Visibility @default(PUBLIC)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  // prisma use userId to create a foreign key constraint to users table
  // it will automatically create an index on userId for faster queries
  // when a user is deleted, all their posts will be deleted as well (cascade delete)
  // FOREIGN KEY (user_id)
  // REFERENCES users(id)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions Reaction[]
  comments  Comment[]
  shares    Share[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("posts")
}

model Reaction {
  id        String       @id @default(uuid())
  userId    String       @map("user_id")
  postId    String       @map("post_id")
  type      ReactionType
  createdAt DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@map("reactions")
}

model Comment {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  postId    String   @map("post_id")
  parentId  String?  @map("parent_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([postId, createdAt(sort: Desc)])
  @@map("comments")
}

model Share {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  postId    String   @map("post_id")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("shares")
}

// ============================================================
// DOMAIN 3 — FRIENDS & CHAT (Realtime messaging)
// ============================================================

model Friendship {
  id          String           @id @default(uuid())
  requesterId String           @map("requester_id")
  addresseeId String           @map("addressee_id")
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@map("friendships")
}

model Conversation {
  id        String           @id @default(uuid())
  type      ConversationType @default(PRIVATE)
  name      String?
  avatarUrl String?          @map("avatar_url")
  createdAt DateTime         @default(now()) @map("created_at")

  members  ConversationMember[]
  messages Message[]

  @@map("conversations")
}

model ConversationMember {
  id             String                 @id @default(uuid())
  conversationId String                 @map("conversation_id")
  userId         String                 @map("user_id")
  role           ConversationMemberRole @default(MEMBER)
  joinedAt       DateTime               @default(now()) @map("joined_at")
  lastReadAt     DateTime?              @map("last_read_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_members")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String      @map("conversation_id")
  senderId       String      @map("sender_id")
  content        String?
  mediaUrl       String?     @map("media_url")
  type           MessageType @default(TEXT)
  isDeleted      Boolean     @default(false) @map("is_deleted")
  createdAt      DateTime    @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}

// ============================================================
// DOMAIN 4 — TRAVEL MAP
// ============================================================

model MapLocation {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  name         String
  description  String?
  latitude     Float
  longitude    Float
  locationType LocationType @map("location_type")
  notes        String?
  coverImage   String?      @map("cover_image")
  isPublic     Boolean      @default(true) @map("is_public")
  visitedAt    DateTime?    @map("visited_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags      LocationTag[]
  favorites LocationFavorite[]
  photos    LocationPhoto[]

  @@index([userId, locationType])
  @@index([latitude, longitude])
  @@map("map_locations")
}

model LocationTag {
  id         String @id @default(uuid())
  locationId String @map("location_id")
  tag        String

  location MapLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([tag])
  @@map("location_tags")
}

model LocationFavorite {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  locationId String   @map("location_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  location MapLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, locationId])
  @@map("location_favorites")
}

model LocationPhoto {
  id         String   @id @default(uuid())
  locationId String   @map("location_id")
  userId     String   @map("user_id")
  photoUrl   String   @map("photo_url")
  caption    String?
  createdAt  DateTime @default(now()) @map("created_at")

  location MapLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([locationId])
  @@map("location_photos")
}

// ============================================================
// DOMAIN 5 — PLANS & TASKS (Trip planning, group project)
// ============================================================

model Plan {
  id          String     @id @default(uuid())
  creatorId   String     @map("creator_id")
  title       String
  description String?
  startDate   DateTime?  @map("start_date") @db.Date
  endDate     DateTime?  @map("end_date") @db.Date
  totalBudget Decimal?   @map("total_budget") @db.Decimal(12, 2)
  currency    String     @default("VND")
  status      PlanStatus @default(DRAFT)
  coverImage  String?    @map("cover_image")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  creator   User          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  members   PlanMember[]
  tasks     Task[]
  expenses  Expense[]
  messages  PlanMessage[]

  @@index([creatorId, status])
  @@map("plans")
}

model PlanMember {
  id       String         @id @default(uuid())
  planId   String         @map("plan_id")
  userId   String         @map("user_id")
  role     PlanMemberRole @default(VIEWER)
  joinedAt DateTime       @default(now()) @map("joined_at")

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([planId, userId])
  @@map("plan_members")
}

model Task {
  id          String       @id @default(uuid())
  planId      String       @map("plan_id")
  assigneeId  String?      @map("assignee_id")
  title       String
  description String?
  dueDate     DateTime?    @map("due_date") @db.Date
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  plan     Plan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  assignee User? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([planId, status])
  @@map("tasks")
}

model Expense {
  id          String          @id @default(uuid())
  planId      String          @map("plan_id")
  paidById    String          @map("paid_by")
  title       String
  amount      Decimal         @db.Decimal(12, 2)
  currency    String          @default("VND")
  category    ExpenseCategory @default(OTHER)
  expenseDate DateTime?       @map("expense_date") @db.Date
  receiptUrl  String?         @map("receipt_url")
  notes       String?
  createdAt   DateTime        @default(now()) @map("created_at")

  plan   Plan @relation(fields: [planId], references: [id], onDelete: Cascade)
  paidBy User @relation(fields: [paidById], references: [id])

  @@index([planId, category])
  @@map("expenses")
}

model PlanMessage {
  id        String   @id @default(uuid())
  planId    String   @map("plan_id")
  senderId  String   @map("sender_id")
  content   String?
  mediaUrl  String?  @map("media_url")
  createdAt DateTime @default(now()) @map("created_at")

  plan   Plan @relation(fields: [planId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([planId, createdAt(sort: Desc)])
  @@map("plan_messages")
}

// ============================================================
// DOMAIN 6 — NOTIFICATIONS
// ============================================================

model Notification {
  id          String                 @id @default(uuid())
  recipientId String                 @map("recipient_id")
  actorId     String?                @map("actor_id")
  type        NotificationType
  entityId    String?                @map("entity_id")
  entityType  NotificationEntityType? @map("entity_type")
  // metadata: store preview text, names, etc. to avoid extra joins
  // e.g. { "post_preview": "...", "plan_name": "Đà Lạt 2025" }
  metadata    Json?
  isRead      Boolean                @default(false) @map("is_read")
  readAt      DateTime?              @map("read_at")
  createdAt   DateTime               @default(now()) @map("created_at")

  recipient User  @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([recipientId, isRead, createdAt(sort: Desc)])
  @@index([recipientId, type])
  @@map("notifications")
}

model NotificationSetting {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  inApp     Boolean          @default(true) @map("in_app")
  push      Boolean          @default(true)
  email     Boolean          @default(false)
  updatedAt DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("notification_settings")
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  platform  Platform
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}